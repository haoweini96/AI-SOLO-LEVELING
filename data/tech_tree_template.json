      {
        "id": "foundations",
        "title": "Foundations",
        "icon": "📐",
        "children": [
          {
            "id": "math_stats",
            "title": "Math & Statistics",
            "children": [
              {
                "id": "linear_algebra",
                "title": "Linear Algebra & Matrix Operations",
                "guide": {
                  "what": "线性代数是研究向量、矩阵和线性变换的数学分支。它提供了处理高维数据和线性关系的数学工具。",
                  "why": "是机器学习的数学基础，几乎所有ML算法都涉及矩阵运算和向量操作。",
                  "resources": [
                    "3Blue1Brown的《线性代数的本质》视频系列",
                    "Gilbert Strang的MIT 18.06课程",
                    "实践：用NumPy实现矩阵运算和特征值分解"
                  ],
                  "prerequisites": [
                    "probability",
                    "optimization"
                  ]
                }
              },
              {
                "id": "probability",
                "title": "Probability & Bayesian Inference",
                "guide": {
                  "what": "概率论研究随机事件的规律，贝叶斯推断是基于先验知识更新概率的方法。它们是处理不确定性的数学框架。",
                  "why": "机器学习本质上是在不确定性下做决策，概率思维是理解模型预测和评估的关键。",
                  "resources": [
                    "《Think Bayes》- 贝叶斯思维入门",
                    "Khan Academy概率统计课程",
                    "用Python实现贝叶斯分类器和A/B测试"
                  ],
                  "prerequisites": [
                    "linear_algebra",
                    "optimization"
                  ]
                }
              },
              {
                "id": "optimization",
                "title": "Optimization Theory",
                "guide": {
                  "what": "优化理论研究如何找到函数的最优值。在机器学习中主要涉及梯度下降、凸优化等方法。",
                  "why": "所有机器学习模型的训练过程本质上都是优化问题，理解优化算法才能调好模型。",
                  "resources": [
                    "《Convex Optimization》by Boyd & Vandenberghe",
                    "Andrew Ng的优化算法讲解",
                    "实现不同的梯度下降变种（SGD, Adam, RMSprop）"
                  ],
                  "prerequisites": [
                    "linear_algebra",
                    "probability"
                  ]
                }
              }
            ]
          },
          {
            "id": "classical_ml",
            "title": "Classical ML",
            "children": [
              {
                "id": "supervised",
                "title": "Supervised Learning",
                "guide": {
                  "what": "监督学习使用标注数据训练模型，包括分类和回归任务。模型学习输入到输出的映射关系。",
                  "why": "是最常见的机器学习范式，大多数实际应用都属于监督学习问题。",
                  "resources": [
                    "《Hands-On Machine Learning》第1-9章",
                    "Scikit-learn官方教程和案例",
                    "Kaggle竞赛实践：从数据预处理到模型调优"
                  ],
                  "prerequisites": [
                    "unsupervised",
                    "feature_eng"
                  ]
                }
              },
              {
                "id": "unsupervised",
                "title": "Unsupervised Learning",
                "guide": {
                  "what": "无监督学习从无标签数据中发现隐藏模式，包括聚类、降维、异常检测等任务。",
                  "why": "现实中大部分数据都是无标签的，无监督学习能挖掘数据的内在结构和价值。",
                  "resources": [
                    "《Pattern Recognition and Machine Learning》第9、12章",
                    "实现K-means、PCA、t-SNE等经典算法",
                    "用无监督学习做客户细分和推荐系统"
                  ],
                  "prerequisites": [
                    "supervised",
                    "feature_eng"
                  ]
                }
              },
              {
                "id": "feature_eng",
                "title": "Feature Engineering & Selection",
                "guide": {
                  "what": "特征工程是从原始数据中提取和构造有用特征的过程。包括特征选择、变换、组合等技术。",
                  "why": "好的特征往往比复杂的算法更重要，特征工程直接决定了模型的上限。",
                  "resources": [
                    "《Feature Engineering for Machine Learning》",
                    "Pandas和Scikit-learn的特征处理工具",
                    "实际项目中的特征工程案例分析"
                  ],
                  "prerequisites": [
                    "supervised",
                    "unsupervised"
                  ]
                }
              }
            ]
          },
          {
            "id": "data_eng",
            "title": "Data Engineering",
            "children": [
              {
                "id": "data_pipelines",
                "title": "Data Pipelines & ETL",
                "guide": {
                  "what": "数据管道是自动化的数据处理流程，ETL指提取、转换、加载数据的过程。确保数据从源头到模型的顺畅流动。",
                  "why": "生产环境中需要稳定、可扩展的数据处理流程，好的数据管道是ML系统的基础设施。",
                  "resources": [
                    "Apache Airflow官方文档和教程",
                    "《Designing Data-Intensive Applications》",
                    "用Docker和Kubernetes部署数据管道"
                  ],
                  "prerequisites": [
                    "data_quality"
                  ]
                }
              },
              {
                "id": "data_quality",
                "title": "Data Quality & Validation",
                "guide": {
                  "what": "数据质量管理包括数据清洗、验证、监控等环节。确保数据的准确性、完整性和一致性。",
                  "why": "垃圾进垃圾出，数据质量直接影响模型效果，是ML项目成功的前提。",
                  "resources": [
                    "Great Expectations数据验证框架",
                    "《The Data Quality Handbook》",
                    "建立数据质量监控和告警系统"
                  ],
                  "prerequisites": [
                    "data_pipelines"
                  ]
                }
              }
            ]
          }
        ]
      },
      {
        "id": "deep_learning",
        "title": "Deep Learning",
        "icon": "🧬",
        "children": [
          {
            "id": "nn_fundamentals",
            "title": "Neural Network Fundamentals",
            "children": [
              {
                "id": "architectures",
                "title": "Architectures (CNN, RNN, Transformer)",
                "guide": {
                  "what": "神经网络架构包括CNN（处理图像）、RNN（处理序列）、Transformer（处理任意序列）等不同的网络设计。",
                  "why": "不同任务需要不同的网络架构，理解架构原理才能选择合适的模型和改进设计。",
                  "resources": [
                    "《Deep Learning》by Goodfellow第6-10章",
                    "PyTorch官方教程：从CNN到Transformer",
                    "实现并对比不同架构在同一任务上的表现"
                  ],
                  "prerequisites": [
                    "training_optimization"
                  ]
                }
              },
              {
                "id": "training_optimization",
                "title": "Training & Optimization",
                "guide": {
                  "what": "神经网络训练优化包括损失函数设计、优化器选择、学习率调度、正则化等技术。",
                  "why": "训练技巧决定了模型能否收敛到好的解，是深度学习实践的核心技能。",
                  "resources": [
                    "《Deep Learning》第8章优化方法",
                    "Fast.ai的训练技巧课程",
                    "实验不同优化策略对训练效果的影响"
                  ],
                  "prerequisites": [
                    "architectures"
                  ]
                }
              }
            ]
          },
          {
            "id": "computer_vision",
            "title": "Computer Vision",
            "children": [
              {
                "id": "image_classification",
                "title": "Image Classification & Detection",
                "guide": {
                  "what": "图像分类是识别图像中物体类别的任务，目标检测进一步定位物体位置。是计算机视觉的基础任务。",
                  "why": "是计算机视觉最成熟的应用领域，掌握后可以扩展到更复杂的视觉任务。",
                  "resources": [
                    "CS231n斯坦福计算机视觉课程",
                    "用PyTorch实现ResNet、YOLO等经典模型",
                    "参与图像分类竞赛（ImageNet、CIFAR）"
                  ],
                  "prerequisites": [
                    "vision_language",
                    "video_understanding"
                  ]
                }
              },
              {
                "id": "vision_language",
                "title": "Vision-Language Models (CLIP, SigLIP)",
                "guide": {
                  "what": "视觉-语言模型如CLIP、SigLIP能同时理解图像和文本，实现跨模态的表示学习和检索。",
                  "why": "多模态AI是未来趋势，视觉-语言模型在搜索、生成、理解等任务中应用广泛。",
                  "resources": [
                    "CLIP论文及OpenAI官方实现",
                    "Hugging Face的多模态模型教程",
                    "构建图文检索和图像描述生成系统"
                  ],
                  "prerequisites": [
                    "image_classification",
                    "video_understanding"
                  ]
                }
              },
              {
                "id": "video_understanding",
                "title": "Video Understanding",
                "guide": {
                  "what": "视频理解涉及动作识别、视频分类、时序建模等任务。需要处理时间维度的视觉信息。",
                  "why": "视频是更丰富的信息载体，视频理解在监控、娱乐、教育等领域有重要应用。",
                  "resources": [
                    "《Two-Stream CNN》等经典视频理解论文",
                    "用3D CNN和LSTM处理视频数据",
                    "实现视频动作识别和视频摘要系统"
                  ],
                  "prerequisites": [
                    "image_classification",
                    "vision_language"
                  ]
                }
              }
            ]
          },
          {
            "id": "nlp_lm",
            "title": "NLP & Language Models",
            "children": [
              {
                "id": "tokenization_embeddings",
                "title": "Tokenization & Embeddings",
                "guide": {
                  "what": "分词是将文本切分成词汇单元的过程，词嵌入将词汇映射为稠密向量表示。是NLP的预处理基础。",
                  "why": "文本需要转换为数值形式才能被模型处理，好的分词和嵌入直接影响NLP模型效果。",
                  "resources": [
                    "《Natural Language Processing with Python》前几章",
                    "Hugging Face Tokenizers库教程",
                    "比较不同分词方法（BPE、WordPiece、SentencePiece）"
                  ],
                  "prerequisites": [
                    "attention_transformer",
                    "finetuning"
                  ]
                }
              },
              {
                "id": "attention_transformer",
                "title": "Attention & Transformer Internals",
                "guide": {
                  "what": "注意力机制让模型关注输入的重要部分，Transformer是基于自注意力的架构。是现代NLP的核心技术。",
                  "why": "Transformer架构是GPT、BERT等大语言模型的基础，理解其原理是掌握现代NLP的关键。",
                  "resources": [
                    "《Attention Is All You Need》原论文详解",
                    "The Illustrated Transformer博客文章",
                    "从零实现Transformer并在翻译任务上训练"
                  ],
                  "prerequisites": [
                    "tokenization_embeddings",
                    "finetuning"
                  ]
                }
              },
              {
                "id": "finetuning",
                "title": "Fine-tuning (LoRA, RLHF, DPO)",
                "guide": {
                  "what": "Fine-tuning是在预训练模型基础上针对特定任务进行优化的技术。LoRA通过低秩适应实现高效微调，RLHF利用人类反馈进行强化学习，DPO直接优化偏好数据。",
                  "why": "掌握这些技术能让你定制化改进模型性能，是构建实用AI应用的核心技能。",
                  "resources": [
                    "阅读LoRA论文并实践Hugging Face PEFT库",
                    "学习OpenAI的RLHF技术报告和实现",
                    "通过Axolotl或类似框架进行hands-on微调实验"
                  ],
                  "prerequisites": [
                    "tokenization_embeddings",
                    "attention_transformer"
                  ]
                }
              }
            ]
          }
        ]
      },
      {
        "id": "llm_apps",
        "title": "LLM & Applications",
        "icon": "🤖",
        "children": [
          {
            "id": "llm_fundamentals",
            "title": "LLM Fundamentals",
            "children": [
              {
                "id": "how_llms_work",
                "title": "How LLMs Work",
                "guide": {
                  "what": "深入理解大语言模型的内部机制，包括Transformer架构、注意力机制、训练过程和推理原理。涵盖从token化到生成的完整流程。",
                  "why": "理解LLM工作原理是有效使用和优化模型的基础，帮助你做出更好的技术决策。",
                  "resources": [
                    "阅读《Attention Is All You Need》论文和相关解析",
                    "观看Andrej Karpathy的GPT系列视频教程",
                    "使用nanoGPT从零实现一个小型语言模型"
                  ],
                  "prerequisites": [
                    "prompt_engineering",
                    "context_engineering"
                  ]
                }
              },
              {
                "id": "prompt_engineering",
                "title": "Prompt Engineering",
                "guide": {
                  "what": "Prompt工程是设计和优化输入提示词的技术，通过精心构造的指令让LLM产生更准确、有用的输出。包括few-shot learning、chain-of-thought等技巧。",
                  "why": "这是与LLM交互的核心技能，直接影响模型输出质量和应用效果。",
                  "resources": [
                    "学习OpenAI和Anthropic的prompt engineering指南",
                    "实践LangChain的prompt templates和优化技巧",
                    "阅读《The Prompt Report》了解最新研究进展"
                  ],
                  "prerequisites": [
                    "how_llms_work",
                    "context_engineering"
                  ]
                }
              },
              {
                "id": "context_engineering",
                "title": "Context Engineering",
                "guide": {
                  "what": "Context工程专注于优化LLM的上下文窗口使用，包括信息组织、上下文压缩、相关性排序等技术。目标是在有限窗口内提供最有价值的信息。",
                  "why": "有效的上下文管理能显著提升LLM的理解能力和回答质量，特别是在复杂任务中。",
                  "resources": [
                    "研究context length optimization的最新论文",
                    "实践LongChain等长上下文处理框架",
                    "学习信息检索和文本摘要技术用于上下文压缩"
                  ],
                  "prerequisites": [
                    "how_llms_work",
                    "prompt_engineering"
                  ]
                }
              }
            ]
          },
          {
            "id": "rag",
            "title": "RAG",
            "children": [
              {
                "id": "vector_db",
                "title": "Vector Databases & Embeddings",
                "guide": {
                  "what": "向量数据库专门存储和检索高维向量数据，embeddings是文本、图像等数据的向量表示。两者结合实现语义搜索和相似性匹配。",
                  "why": "这是构建RAG系统和语义搜索应用的核心基础设施。",
                  "resources": [
                    "实践Pinecone、Weaviate或Chroma等向量数据库",
                    "学习不同embedding模型的特点和选择策略",
                    "构建一个端到端的语义搜索demo项目"
                  ],
                  "prerequisites": [
                    "retrieval_strategies",
                    "rag_pipeline"
                  ]
                }
              },
              {
                "id": "retrieval_strategies",
                "title": "Retrieval Strategies",
                "guide": {
                  "what": "检索策略是从大量文档中找到相关信息的方法，包括密集检索、稀疏检索、混合检索、重排序等技术。",
                  "why": "好的检索策略直接决定RAG系统的效果，是信息检索应用的核心。",
                  "resources": [
                    "学习BM25、DPR等经典检索算法",
                    "实践Haystack或LlamaIndex的检索组件",
                    "研究最新的retrieval augmentation技术论文"
                  ],
                  "prerequisites": [
                    "vector_db",
                    "rag_pipeline"
                  ]
                }
              },
              {
                "id": "rag_pipeline",
                "title": "RAG Pipeline Design",
                "guide": {
                  "what": "RAG管道设计涵盖从文档处理、向量化、检索到生成的完整流程。包括数据预处理、chunk策略、检索优化、答案生成等环节的设计。",
                  "why": "掌握端到端的RAG系统设计是构建知识密集型AI应用的必备技能。",
                  "resources": [
                    "使用LangChain或LlamaIndex构建完整RAG系统",
                    "学习advanced RAG技术如HyDE、Self-RAG等",
                    "参考Microsoft的RAG系统设计最佳实践"
                  ],
                  "prerequisites": [
                    "vector_db",
                    "retrieval_strategies"
                  ]
                }
              }
            ]
          },
          {
            "id": "llm_eval",
            "title": "LLM Evaluation & Safety",
            "children": [
              {
                "id": "eval_frameworks",
                "title": "Benchmarks & Eval Frameworks",
                "guide": {
                  "what": "评估框架和基准测试用于衡量LLM在各种任务上的性能，包括MMLU、HellaSwag等标准基准，以及自定义评估指标。",
                  "why": "客观评估是模型选择、优化和部署决策的科学依据。",
                  "resources": [
                    "熟悉Hugging Face Evaluate库和主流benchmark",
                    "学习使用HELM、lm-evaluation-harness等评估工具",
                    "研究如何设计针对特定应用的评估指标"
                  ],
                  "prerequisites": [
                    "alignment_safety"
                  ]
                }
              },
              {
                "id": "alignment_safety",
                "title": "Alignment & Safety",
                "guide": {
                  "what": "对齐与安全研究确保AI系统的行为符合人类价值观和预期，包括有害内容检测、偏见缓解、可解释性等方面。",
                  "why": "这是负责任AI开发的核心要求，对构建可信赖的AI系统至关重要。",
                  "resources": [
                    "阅读Anthropic关于Constitutional AI的研究",
                    "学习使用safety evaluation工具如Perspective API",
                    "关注AI safety领域的最新研究进展和标准"
                  ],
                  "prerequisites": [
                    "eval_frameworks"
                  ]
                }
              }
            ]
          }
        ]
      },
      {
        "id": "ai_agents",
        "title": "AI Agents",
        "icon": "🕵️",
        "children": [
          {
            "id": "agent_fundamentals",
            "title": "Agent Fundamentals",
            "children": [
              {
                "id": "agent_patterns",
                "title": "Agent Architecture Patterns",
                "guide": {
                  "what": "Agent架构模式定义了AI智能体的设计框架，包括ReAct、Plan-and-Execute、Reflexion等模式。每种模式适用于不同类型的任务和场景。",
                  "why": "理解不同架构模式帮助你为具体应用选择最合适的agent设计方案。",
                  "resources": [
                    "实践LangGraph构建不同架构模式的agent",
                    "阅读《ReAct: Synergizing Reasoning and Acting》等经典论文",
                    "参考AutoGPT、LangChain Agents的实现案例"
                  ],
                  "prerequisites": [
                    "tool_use",
                    "memory_systems"
                  ]
                }
              },
              {
                "id": "tool_use",
                "title": "Tool Use & Function Calling",
                "guide": {
                  "what": "工具使用和函数调用让AI agent能够调用外部API、执行代码、访问数据库等，扩展其能力边界。包括工具选择、参数生成、结果处理等环节。",
                  "why": "这是构建实用AI助手的关键能力，让agent能够完成现实世界的复杂任务。",
                  "resources": [
                    "学习OpenAI Function Calling和Tool Use API",
                    "实践LangChain Tools和Toolkits的使用",
                    "构建一个能调用多种工具的实用agent项目"
                  ],
                  "prerequisites": [
                    "agent_patterns",
                    "memory_systems"
                  ]
                }
              },
              {
                "id": "memory_systems",
                "title": "Memory Systems",
                "guide": {
                  "what": "记忆系统让AI agent能够存储和检索历史信息，包括短期记忆、长期记忆、情景记忆等类型。实现方式包括向量存储、图数据库、结构化存储等。",
                  "why": "记忆能力使agent能够进行连续对话和学习，是构建智能助手的重要组件。",
                  "resources": [
                    "研究MemGPT等长期记忆架构的实现",
                    "实践使用Redis、Neo4j等构建agent记忆系统",
                    "学习episodic memory和semantic memory的设计模式"
                  ],
                  "prerequisites": [
                    "agent_patterns",
                    "tool_use"
                  ]
                }
              }
            ]
          },
          {
            "id": "multi_agent",
            "title": "Multi-Agent Systems",
            "children": [
              {
                "id": "orchestration",
                "title": "Orchestration Patterns",
                "guide": {
                  "what": "编排模式定义了多个agent之间的协调和任务分配机制，包括中心化控制、分布式协调、层次化管理等不同的组织方式。",
                  "why": "掌握编排模式能够构建复杂的多agent系统，实现大规模协作任务。",
                  "resources": [
                    "学习Microsoft AutoGen的multi-agent编排框架",
