# AI Solo Leveling — Environment Variables
# Copy this to .env and fill in your API keys

# Required: Claude AI for knowledge extraction, quiz generation, coverage evaluation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: OpenAI for some analysis features
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Google Gemini for alternative AI features
GEMINI_API_KEY=your_gemini_api_key_here
